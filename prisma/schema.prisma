generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Farmer / land customer record (full detail for admin).
model Customer {
  id        Int      @id @default(autoincrement())
  slNo      Int?
  createdAt DateTime @default(now())

  // --- Basic ---
  farmerName        String?
  changedFarmerName String?
  vendorCode        String?
  surveyNo          String?
  newSurveyNo       String?

  // --- RTC ---
  rtcExtentAcre  Float?
  rtcExtentGunta Float?
  rtcAKharab     Float?
  rtcBKharab     Float?

  // --- Balance extent ---
  balanceExtentAcre  Float?
  balanceExtentGunta Float?

  // --- Lease ---
  leaseExtentAcre        Float?
  leaseExtentGunta       Float?
  leaseAmount            Float?
  leaseDeedStampDuty     Float?
  leaseDeedRegCharges    Float?

  // --- Area totals ---
  totalGunta Float?
  totalCents Float?

  // --- Rent ---
  rentPerAcre       Float?
  balanceRentAmount Float?
  rentAmount        Float?
  tdsAmount         Float?

  // --- AES advance ---
  aesAdvanceChequeAmount Float?
  aesAdvanceDate         String? // YYYY-MM-DD
  aesAdvanceChequeNo     String?
  aesAdvanceBankName     String?

  // --- Shortage ---
  shortageChequeAmount Float?
  shortageDate         String? // YYYY-MM-DD
  shortageChequeNo     String?
  shortageBankName     String?

  // --- ATL / PAO ---
  atlStampDuty  Float?
  atlRegCharges Float?
  atlTotal      Float?
  paoStampDuty  Float?
  paoRegCharges Float?
  paoTotal      Float?

  // --- Other charges ---
  landConversion   Float?
  podiFee          Float?
  otherCharges     Float?
  cropCompensation Float?

  // --- Debit note ---
  debitNoteNo     String?
  debitNoteAmount Float?

  // --- Received ---
  receivedNeftAmount Float?
  receivedDate       String? // YYYY-MM-DD
  balanceReceivable  Float?

  // --- Other ---
  loanAmount Float?
  notes      String? // Remark
}

/// GST / invoice customer (separate from farmer Customer records).
model GstCustomer {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  mobile         String?
  email          String?
  gstNumber      String   @unique
  companyName    String?
  companyAddress String?
  state          String?
  gstStatus      String?
  panNumber      String?
  notes          String?
  createdAt      DateTime @default(now())

  invoices Invoice[]

  @@map("gst_customers")
}

/// Generated invoice (NA or Service).
model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceType   String // "na" | "service"
  subType       String
  customerId    Int
  invoiceNumber String   @unique
  invoiceDate   String // YYYY-MM-DD
  status        String   @default("draft") // draft | final
  ratePerAcre    Float?
  subtotal      Float    @default(0)
  sgst          Float    @default(0)
  cgst          Float    @default(0)
  grandTotal    Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  customer GstCustomer   @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  farmerId    Int?
  village     String?
  surveyNo    String?
  naExtent    String?
  acres       Float?
  gunta       Float?
  totalCents  Float?
  affidavitId String?
  requestId   String?
  amount      Float   @default(0)
  description String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
