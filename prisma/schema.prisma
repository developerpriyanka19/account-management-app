generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Farmer / land customer record (full detail for admin).
model Customer {
  id        Int      @id @default(autoincrement())
  slNo      Int?
  createdAt DateTime @default(now())

  // --- Basic ---
  farmerName        String?
  changedFarmerName String?
  vendorCode        String?
  surveyNo          String?
  newSurveyNo       String?

  // --- RTC ---
  rtcExtentAcre  Float?
  rtcExtentGunta Float?
  rtcAKharab     Float?
  rtcBKharab     Float?

  // --- Balance extent ---
  balanceExtentAcre  Float?
  balanceExtentGunta Float?

  // --- Lease ---
  leaseExtentAcre        Float?
  leaseExtentGunta       Float?
  leaseAmount            Float?
  leaseDeedStampDuty     Float?
  leaseDeedRegCharges    Float?

  // --- Area totals ---
  totalGunta Float?
  totalCents Float?

  // --- Rent ---
  rentPerAcre       Float?
  balanceRentAmount Float?
  rentAmount        Float?
  tdsAmount         Float?

  // --- AES advance ---
  aesAdvanceChequeAmount Float?
  aesAdvanceDate         String? // YYYY-MM-DD
  aesAdvanceChequeNo     String?
  aesAdvanceBankName     String?

  // --- Shortage ---
  shortageChequeAmount Float?
  shortageAmountFirstTime Float?
  shortageAmountSecondTime Float?
  shortageDate         String? // YYYY-MM-DD
  shortageChequeNo     String?
  shortageBankName     String?
  shortageSecondDate      String? // YYYY-MM-DD
  shortageSecondChequeNo  String?
  shortageSecondBankName  String?

  // --- ATL / PAO ---
  atlStampDuty  Float?
  atlRegCharges Float?
  atlTotal      Float?
  paoStampDuty  Float?
  paoRegCharges Float?
  paoTotal      Float?

  // --- Other charges ---
  landConversion   Float?
  podiFee          Float?
  otherCharges     Float?
  cropCompensation Float?

  // --- Debit note ---
  debitNoteNo     String?
  debitNoteAmount Float?

  // --- Received ---
  receivedNeftAmount Float?
  receivedDate       String? // YYYY-MM-DD
  balanceReceivable  Float?

  // --- Other ---
  loanAmount Float?
  notes      String? // Remark
}

/// GST / invoice customer (separate from farmer Customer records).
model GstCustomer {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  mobile         String?
  email          String?
  gstNumber      String   @unique
  companyName    String?
  companyAddress String?
  buildingNumber String?
  street         String?
  locality       String?
  village        String?
  district       String?
  pincode        String?
  state          String?
  gstStatus      String?
  panNumber      String?
  notes          String?
  createdAt      DateTime @default(now())

  invoices Invoice[]
  debitNotes DebitNote[]

  @@map("gst_customers")
}

/// Generated invoice (NA or Service).
model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceType   String // "na" | "service"
  subType       String
  customerId    Int
  invoiceNumber String   @unique
  invoiceDate   String // YYYY-MM-DD
  district      String?
  taluk         String?
  village       String?
  hobbli        String?
  status        String   @default("draft") // draft | final
  ratePerAcre   Float?
  subtotal      Float    @default(0)
  sgst          Float    @default(0)
  cgst          Float    @default(0)
  grandTotal    Float    @default(0)
  totalAmountWords String?
  pdfUrl        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer GstCustomer   @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  farmerId    Int?
  district    String?
  taluk       String?
  village     String?
  hobbli      String?
  surveyNo    String?
  naExtent    String?
  acres       Float?
  gunta       Float?
  totalCents  Float?
  affidavitId String?
  requestId   String?
  debitNote   Float    @default(0)
  remark      String?
  amount      Float   @default(0)
  description String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model DebitNote {
  id            Int      @id @default(autoincrement())
  type          String   // "land-conversion" | "atl-poa-gpa"
  customerId    Int
  debitNoteNo   String   @unique
  date          String // YYYY-MM-DD
  district      String?
  taluk         String?
  village       String?
  hobbli        String?
  subtotal      Float    @default(0)
  gst           Float    @default(0)
  total         Float    @default(0)
  remarks       String?
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer GstCustomer @relation(fields: [customerId], references: [id])
  items    DebitNoteItem[]

  @@map("debit_notes")
}

model DebitNoteItem {
  id                  Int     @id @default(autoincrement())
  debitNoteId         Int
  farmerId            Int?
  farmerName          String?
  surveyNo            String?
  acres               Float?
  guntas              Float?
  rtcAcre             Float?
  rtcGunta            Float?
  leaseAcre           Float?
  leaseGunta          Float?
  landConversionFee   Float?
  landConversionChallanRefNo String?
  podiFee             Float?
  podiChallanRefNo    String?
  recoveryFee         Float?
  recoveryChallanRefNo String?
  atlCharges          Float?
  poaCharges          Float?
  chequePart1Amount   Float?
  chequePart1Date     String?
  chequePart1No       String?
  chequePart1BankName String?
  chequePart2Amount   Float?
  chequePart2Date     String?
  chequePart2No       String?
  chequePart2BankName String?
  cashAmount          Float?
  remarks             String?
  total               Float   @default(0)

  debitNote DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)

  @@map("debit_note_items")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
